{
  "name": "@my-assistant/client",
  "version": "0.1.142",
  "private": true,
  "description": "my-assistant Angular client — Dynamo NGX + FDP NGX templates + Material + Tailwind.",
  "DyBu_settings": {
    "packageType": "client",
    "systemName": "my-assistant"
  },
  "scripts": {
    "ng": "ng",
    "prep": "npm i -g pnpm rimraf @angular/cli && pnpm i",
    "clean": "rimraf ./dist && rimraf ./.angular && rimraf package-lock.json && rimraf pnpm-lock.yaml && rimraf ./node_modules",
    "soft-clean": "rimraf ./dist && rimraf ./.angular && rimraf pnpm-lock.yaml",
    "build-base": "ng build --configuration production --base-href /",
    "build": "npm run build-base && npm test",
    "build-clean": "npm run clean && npm run build-base",
    "start": "ng serve --port=4224 --host=127.0.0.1",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "test:coverage": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "validate:imports": "dynamo-validate-imports",
    "validate:naming": "dynamo-validate-naming"
  },
  "dependencies": {
    "@angular/animations": "~18.2.13",
    "@angular/cdk": "~18.2.14",
    "@angular/common": "~18.2.13",
    "@angular/compiler": "~18.2.13",
    "@angular/core": "~18.2.13",
    "@angular/forms": "~18.2.13",
    "@angular/material": "~18.2.14",
    "@angular/platform-browser": "~18.2.13",
    "@angular/platform-browser-dynamic": "~18.2.13",
    "@angular/router": "~18.2.13",
    "@futdevpro/fdp-templates": "1.15.24",
    "@futdevpro/fsm-dynamo": "1.15.9",
    "@futdevpro/ngx-dynamo": "18.15.9",
    "@futdevpro/ngx-dynamo-models": "1.15.8",
    "@futdevpro/ngx-fdp-templates": "18.15.15",
    "@kolkov/angular-editor": "3.0.0-beta.0",
    "@types/crypto-js": "~4.2.2",
    "crypto-js": "~4.2.0",
    "ngx-image-compress": "~15.1.6",
    "ngx-image-cropper": "~7.2.1",
    "ngx-mask": "~17.0.9",
    "rxjs": "7.8.1",
    "socket.io-client": "~4.8.1",
    "tslib": "~2.3.0",
    "uuid": "11.1.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~18.2.12",
    "@angular-eslint/eslint-plugin": "19.0.0",
    "@angular-eslint/eslint-plugin-template": "19.0.0",
    "@angular-eslint/template-parser": "19.0.0",
    "@angular/cli": "~18.2.12",
    "@angular/compiler-cli": "~18.2.13",
    "@futdevpro/dynamo-eslint": "1.15.8",
    "@types/jasmine": "~5.1.0",
    "@types/uuid": "~10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "~10.4.18",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsdoc": "^48.0.0",
    "eslint-plugin-max-params-no-constructor": "^0.0.4",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "~8.4.35",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.10",
    "tailwindcss": "~3.4.1",
    "typescript": "~5.5.4"
  }
}
