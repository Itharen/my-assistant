# my-assistant server config — copy to .env (gitignored) and fill in.

# Listening port. Default 39245 (FDP konvenció: project XY=24 → 39245 http,
# 39247 notif socket, 39924 service socket). Lásd DEC-MA-009.
MA_SERVER_PORT=39245

# SQLite DB file path. Default: data/my-assistant.db (relative to server/ root).
MA_DB_PATH=data/my-assistant.db

# Bearer token required on POST endpoints (Phase 1 = loopback-only by default).
# Generate a strong random string. Empty = auth-disabled (dev only).
MA_AUTH_TOKEN=

# Bind host. 127.0.0.1 = loopback-only (default Phase 1).
# Set to 0.0.0.0 to expose on LAN (only with MA_AUTH_TOKEN set).
MA_BIND_HOST=127.0.0.1
