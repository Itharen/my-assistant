{
  "name": "@my-assistant/server",
  "version": "0.1.177",
  "private": true,
  "description": "my-assistant server — DyNTS + FDP framework, MongoDB-backed.",
  "type": "module",
  "main": "index.ts",
  "DyBu_settings": {
    "packageType": "server",
    "systemName": "my-assistant"
  },
  "scripts": {
    "prep": "npm i -g pnpm rimraf nodemon copyfiles jasmine typescript && pnpm i",
    "start": "npm run prep && nodemon",
    "start-dev": "node ../node_modules/tsx/dist/cli.mjs ./src/index.ts",
    "build": "npm run build-base",
    "start-prod": "node ./scripts/pre-kill-port.mjs && node ../node_modules/tsx/dist/cli.mjs ./src/index.ts",
    "build-base": "rimraf ./build && tsc",
    "build-clean": "rimraf ./build && rimraf pnpm-lock.yaml && rimraf ./node_modules && pnpm i && tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf ./build && rimraf pnpm-lock.yaml && rimraf ./node_modules",
    "nodemon-run": "node ../node_modules/tsx/dist/cli.mjs ./src/index.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "validate:imports": "dynamo-validate-imports",
    "validate:naming": "dynamo-validate-naming"
  },
  "dependencies": {
    "@futdevpro/fdp-templates": "1.15.24",
    "@futdevpro/fsm-dynamo": "1.15.9",
    "@futdevpro/ngx-dynamo-models": "1.15.8",
    "@futdevpro/nts-dynamo": "1.15.17",
    "@futdevpro/nts-fdp-templates": "1.15.28",
    "crypto-js": "~4.2.0",
    "express": "4.21.2",
    "mongoose": "~8.10.1",
    "rxjs": "7.8.1",
    "socket.io": "~4.8.1",
    "socket.io-client": "~4.8.1",
    "ts-node": "~10.9.2",
    "tslib": "~2.6.2",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@futdevpro/dynamo-eslint": "1.15.8",
    "@types/express": "4.17.21",
    "@types/jasmine": "~5.1.0",
    "@types/node": "~20.11.0",
    "@types/uuid": "~10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsdoc": "^48.0.0",
    "eslint-plugin-max-params-no-constructor": "^0.0.4",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "nodemon": "~3.1.0",
    "prettier": "^3.3.0",
    "rimraf": "^5.0.10",
    "typescript": "5.5.4"
  }
}
