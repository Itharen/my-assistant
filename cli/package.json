{
  "name": "@my-assistant/cli",
  "version": "0.1.118",
  "private": true,
  "description": "my-assistant CLI — TTS push to Google Home / Nest speakers, Spotify resume, volume orchestration. Self-built, FOSS-only.",
  "type": "module",
  "bin": {
    "ma": "./bin/ma.js"
  },
  "files": [
    "bin/",
    "dist/",
    "config/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "prep": "npm i -g pnpm rimraf && pnpm i",
    "clean": "rimraf ./dist && rimraf package-lock.json && rimraf pnpm-lock.yaml && rimraf ./node_modules",
    "soft-clean": "rimraf ./dist && rimraf package-lock.json && rimraf pnpm-lock.yaml",
    "prepack": "npm run build-base",
    "build-base": "rimraf ./dist && tsc -p tsconfig.json",
    "build": "npm run build-base && npm test",
    "build-clean": "npm run clean && npm run build-base",
    "build-n-test": "pnpm run prep && pnpm run build-base && pnpm test && npm i -g --force && ma --help",
    "typecheck": "tsc --noEmit",
    "test": "npm run build-base && jasmine --config=spec/support/jasmine.json",
    "test:coverage": "npm run build-base && c8 --reporter=text --reporter=lcov --reporter=html jasmine --config=spec/support/jasmine.json",
    "discover": "tsx src/main.ts cast discover",
    "notify": "tsx src/main.ts cast notify",
    "volume": "tsx src/main.ts cast volume",
    "preset": "tsx src/main.ts cast preset",
    "list-interfaces": "tsx src/main.ts cast list-interfaces",
    "spotify:auth": "tsx src/main.ts spotify auth",
    "spotify:status": "tsx src/main.ts spotify status",
    "google:auth": "tsx src/main.ts google auth",
    "google:status": "tsx src/main.ts google status",
    "google:query": "tsx src/main.ts google query"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "castv2-client": "^1.2.0",
    "google-assistant": "^0.7.0",
    "msedge-tts": "^2.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msedge-tts",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@types/jasmine": "^5.1.4",
    "@types/node": "^20.11.0",
    "c8": "^10.1.3",
    "jasmine": "^5.1.0",
    "rimraf": "^5.0.10",
    "tsx": "^4.7.0",
    "typescript": "^5.5.4"
  }
}
