{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    // FONTOS: explicit `rootDirs` (NEM `rootDir`) — a `current/principles/ssot.md`
    // cross-subproject pattern szerint a CLI `import type` segítségével a server
    // _models-ből veszi a kanonikus DTO-kat (`@server/_models/...`). Egy sima
    // `rootDir: ./src` TS6059-cel pukkanna; a `rootDir` teljes hiánya emit-en
    // TS5011-gyel pukkan (common source dir = '..'). A `rootDirs` array
    // explicit multi-root layout-ot ad, és emit-time-ban a type-import-ok
    // erase-elődnek, így a `dist/` csak CLI source-okat tartalmaz.
    "rootDirs": ["./src", "./../server/src"],
    "declaration": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "types": ["node", "jasmine"],
    "paths": {
      "@cli/*":    ["./src/*"],
      "@server/*": ["./../server/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
